@page "/orders"
@using OrderTracker.Services
@using OrderTracker.Models
@inject OrderService OrderSvc
@inject CarrierService CarrierSvc
@inject PaymentMethodService PaymentMethodSvc
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>@AppText.PageTitleOrders</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">@AppText.OrdersTitle</h1>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreateModal">@AppText.NewOrderButton</button>
</div>

<div class="filters-bar">
    <div class="search-wrap">
        <input class="search-input" type="text" placeholder="@AppText.SearchOrdersPlaceholder"
               @bind="searchText" @bind:event="oninput" @bind:after="FilterOrders" />
    </div>
    <div class="filter-wrap">
        <select class="filter-select" @bind="selectedStatus" @bind:after="FilterOrders">
            <option value="">@AppText.AllStatusesOption</option>
            @foreach (var status in Enum.GetValues<OrderStatus>())
            {
                <option value="@status">@AppText.GetOrderStatusLabel(status)</option>
            }
        </select>
    </div>
    <div class="sort-wrap">
        <select class="filter-select" @bind="sortField" @bind:after="FilterOrders">
            <option value="date-desc">@AppText.SortDateNewest</option>
            <option value="date-asc">@AppText.SortDateOldest</option>
            <option value="price-desc">@AppText.SortPriceHighest</option>
            <option value="price-asc">@AppText.SortPriceLowest</option>
        </select>
    </div>
</div>

@if (loading)
{
    <div class="loading-state">@AppText.LoadOrders</div>
}
else if (!filteredOrders.Any())
{
    <div class="empty-state">
        <div class="empty-icon">@AppText.EmptyOrdersIcon</div>
        <h3>@AppText.NoOrdersTitle</h3>
        <p>@(string.IsNullOrEmpty(searchText) && string.IsNullOrEmpty(selectedStatus) ? AppText.EmptyOrdersMessage : AppText.NoOrdersWithFiltersMessage)</p>
        @if (string.IsNullOrEmpty(searchText) && string.IsNullOrEmpty(selectedStatus))
        {
            <button class="btn btn-primary" @onclick="OpenCreateModal">@AppText.CreateOrderButton</button>
        }
    </div>
}
else
{
    <div class="table-container">
        <table class="orders-table">
            <thead>
                <tr>
                    <th>@AppText.ColumnStore</th>
                    <th>@AppText.ColumnDate</th>
                    <th>@AppText.ColumnCarrier</th>
                    <th>@AppText.ColumnTracking</th>
                    <th>@AppText.ColumnStatus</th>
                    <th>@AppText.ColumnEstimatedOrReceived</th>
                    <th>@AppText.ColumnTotal</th>
                    <th>@AppText.ColumnActions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in PagedOrders)
                {
                    <tr class="order-row order-row-@order.Status.ToString().ToLower()">
                        <td>
                            <span class="store-name">@order.Store</span>
                            @if (!string.IsNullOrEmpty(order.Notes))
                            {
                                <span class="order-notes" data-tooltip="@order.Notes">@AppText.InfoIcon</span>
                            }
                        </td>
                        <td class="date-cell">@order.PurchaseDate.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="company-badge">@(order.Carrier?.Name ?? AppText.EmptyValue)</span>
                        </td>
                        <td class="tracking-cell">
                            @if (!string.IsNullOrEmpty(order.TrackingUrl))
                            {
                                <a href="@order.TrackingUrl" target="_blank" class="tracking-link" title="@AppText.OpenTrackingTitle">
                                    @(order.TrackingCode ?? AppText.ViewTrackingText) @AppText.ExternalLinkArrow
                                </a>
                            }
                            else if (!string.IsNullOrEmpty(order.TrackingCode))
                            {
                                <span class="tracking-code">@order.TrackingCode</span>
                            }
                            else
                            {
                                <span class="no-tracking">@AppText.EmptyValue</span>
                            }
                        </td>
                        <td>
                            <div class="custom-dropdown">
                                <button class="status-badge status-@order.Status.ToString().ToLower() dropdown-trigger"
                                        @onclick="e => ToggleDropdown(order.Id, e)"
                                        @onclick:stopPropagation="true">
                                    @AppText.GetOrderStatusLabel(order.Status) @AppText.DropdownArrow
                                </button>
                                @if (openDropdownId == order.Id)
                                {
                                    <div class="dropdown-menu" style="top: @(dropdownTop)px; left: @(dropdownLeft)px;" @onclick:stopPropagation="true">
                                        @foreach (var status in Enum.GetValues<OrderStatus>())
                                        {
                                            <div class="dropdown-item @(status == order.Status ? "active" : string.Empty)"
                                                 @onclick="() => ChangeStatusFromDropdown(order.Id, status)">
                                                <span class="status-dot status-dot-@status.ToString().ToLower()"></span>
                                                @AppText.GetOrderStatusLabel(status)
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </td>
                        <td class="@(IsDelayed(order) ? "delayed-date" : string.Empty)">
                            @if (order.Status == OrderStatus.Recibido && order.ReceivedDate.HasValue)
                            {
                                <span class="received-date">@order.ReceivedDate.Value.ToString("dd/MM/yyyy")</span>
                                <span class="days-badge" title="@AppText.DaysSincePurchaseTitle">@((order.ReceivedDate.Value.Date - order.PurchaseDate.Date).Days)d</span>
                            }
                            else if (order.EstimatedDelivery.HasValue)
                            {
                                @order.EstimatedDelivery.Value.ToString("dd/MM/yyyy")
                                @if (IsDelayed(order))
                                {
                                    <span class="delay-badge">@AppText.DelayedLabel</span>
                                }
                            }
                            else
                            {
                                <span class="no-data">@AppText.EmptyValue</span>
                            }
                        </td>
                        <td class="price-cell">@AppText.FormatCurrency(order.TotalPrice)</td>
                        <td>
                            <div class="action-btns">
                                @if (!string.IsNullOrEmpty(order.TrackingUrl))
                                {
                                    <a href="@order.TrackingUrl" target="_blank" class="btn-icon btn-track mobile-track-btn" title="@AppText.TrackingTitle">@AppText.TrackIcon</a>
                                }
                                <button class="btn-icon btn-edit" @onclick="() => OpenEditModal(order)" title="@AppText.EditTitle">@AppText.EditIcon</button>
                                <button class="btn-icon btn-delete" @onclick="() => ConfirmDelete(order)" title="@AppText.DeleteTitle">@AppText.CloseIcon</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="table-footer">
            <span>@AppText.FormatPaginationSummary((currentPage - 1) * pageSize + 1, Math.Min(currentPage * pageSize, filteredOrders.Count), filteredOrders.Count)</span>
            <div class="pagination">
                @if (TotalPages > 1)
                {
                    <button class="page-btn" @onclick="PrevPage" disabled="@(currentPage == 1)">@AppText.PreviousPageArrow</button>
                    @for (var page = 1; page <= TotalPages; page++)
                    {
                        var pageNum = page;
                        <button class="page-btn @(pageNum == currentPage ? "active" : string.Empty)" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                    }
                    <button class="page-btn" @onclick="NextPage" disabled="@(currentPage == TotalPages)">@AppText.NextPageArrow</button>
                }
            </div>
            <div class="page-size-wrap">
                <span class="page-size-label">@AppText.OrdersPerPageLabel</span>
                <div class="custom-dropdown @(pageSizeDropdownOpen ? "open" : string.Empty)">
                    <button class="page-size-btn" @onclick="TogglePageSizeDropdown" @onclick:stopPropagation="true">
                        @pageSize @AppText.DropdownArrow
                    </button>
                    @if (pageSizeDropdownOpen)
                    {
                        <div class="dropdown-menu dropdown-menu-up" style="bottom: calc(100% + 4px); top: auto; left: 0; position: absolute;" @onclick:stopPropagation="true">
                            @foreach (var size in new[] { 10, 15, 20 })
                            {
                                var currentSize = size;
                                <div class="dropdown-item @(currentSize == pageSize ? "active" : string.Empty)" @onclick="() => SetPageSize(currentSize)">@currentSize</div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-panel" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@(editingOrder?.Id > 0 ? AppText.EditOrderTitle : AppText.CreateOrderTitle)</h2>
                <button class="modal-close" @onclick="CloseModal">@AppText.CloseIcon</button>
            </div>
            <div class="modal-body">
                @if (editingOrder != null)
                {
                    <div class="form-section">
                        <h3 class="form-section-title">@AppText.OrderInformationTitle</h3>
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">@AppText.StoreLabel</label>
                                <input class="form-input" @bind="editingOrder.Store" placeholder="@AppText.StorePlaceholder" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">@AppText.PurchaseDateLabel</label>
                                <input class="form-input" type="date" @bind="editingOrder.PurchaseDate" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">@AppText.StatusLabel</label>
                                <select class="form-select" @bind="editingOrder.Status">
                                    @foreach (var status in Enum.GetValues<OrderStatus>())
                                    {
                                        <option value="@status">@AppText.GetOrderStatusLabel(status)</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">@AppText.PaymentMethodLabel</label>
                                <select class="form-select" @bind="editingOrder.PaymentMethodId">
                                    <option value="">@AppText.NoPaymentMethodOption</option>
                                    @foreach (var paymentMethod in paymentMethods)
                                    {
                                        <option value="@paymentMethod.Id">@paymentMethod.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">@AppText.EstimatedDeliveryLabel</label>
                                <input class="form-input" type="date" @bind="editingOrder.EstimatedDelivery" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">@AppText.ReceivedDateLabel</label>
                                <input class="form-input" type="date" @bind="editingOrder.ReceivedDate" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">@AppText.CarrierLabel</label>
                                <select class="form-select" @bind="editingOrder.CarrierId">
                                    <option value="">@AppText.NoCarrierOption</option>
                                    @foreach (var carrier in carriers)
                                    {
                                        <option value="@carrier.Id">@carrier.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">@AppText.TrackingCodeLabel</label>
                                <input class="form-input" @bind="editingOrder.TrackingCode" placeholder="@AppText.TrackingCodePlaceholder" />
                            </div>
                            <div class="form-group form-full">
                                <label class="form-label">@AppText.TrackingUrlLabel</label>
                                <input class="form-input" @bind="editingOrder.TrackingUrl" placeholder="@AppText.TrackingUrlPlaceholder" />
                            </div>
                            <div class="form-group form-full">
                                <label class="form-label">@AppText.NotesLabel</label>
                                <textarea class="form-input form-textarea" @bind="editingOrder.Notes" placeholder="@AppText.NotesPlaceholder"></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="form-section">
                        <div class="section-header-row">
                            <h3 class="form-section-title">@AppText.ProductsTitle</h3>
                            <button class="btn btn-secondary btn-sm" @onclick="AddItem">@AppText.AddProductButton</button>
                        </div>

                        @if (editingOrder.Items.Any())
                        {
                            <div class="items-table">
                                <div class="items-header">
                                    <span>@AppText.ProductLabel</span>
                                    <span>@AppText.QuantityLabel</span>
                                    <span>@AppText.UnitPriceLabel</span>
                                    <span>@AppText.SubtotalLabel</span>
                                    <span></span>
                                </div>
                                @foreach (var item in editingOrder.Items.ToList())
                                {
                                    <div class="items-row">
                                        <input class="form-input" @bind="item.ProductName" placeholder="@AppText.ProductNamePlaceholder" />
                                        <input class="form-input form-input-sm" type="number" min="1" @bind="item.Quantity" @bind:after="RecalcTotal" />
                                        <input class="form-input form-input-sm" type="number" min="0" step="0.01" @bind="item.UnitPrice" @bind:after="RecalcTotal" />
                                        <span class="item-subtotal">@AppText.FormatCurrency(item.Quantity * item.UnitPrice)</span>
                                        <button class="btn-icon btn-delete btn-sm" @onclick="() => RemoveItem(item)">@AppText.CloseIcon</button>
                                    </div>
                                }
                                <div class="items-total">
                                    <span>@AppText.TotalUppercaseLabel</span>
                                    <span></span>
                                    <span></span>
                                    <strong>@AppText.FormatCurrency(editingOrder.TotalPrice)</strong>
                                    <span></span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="empty-items">@AppText.EmptyProductsMessage</div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <div class="form-error">@formError</div>
                    }
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseModal">@AppText.CancelButton</button>
                <button class="btn btn-primary" @onclick="SaveOrder" disabled="@saving">
                    @(saving ? AppText.Saving : AppText.SaveOrderButton)
                </button>
            </div>
        </div>
    </div>
}

@if (orderToDelete != null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-panel modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@AppText.DeleteOrderDialogTitle</h2>
                <button class="modal-close" @onclick="CancelDelete">@AppText.CloseIcon</button>
            </div>
            <div class="modal-body">
                <p>@AppText.FormatDeleteOrderMessage(orderToDelete.Store)</p>
                <p class="delete-warning">@AppText.DeleteOrderWarning</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CancelDelete">@AppText.CancelButton</button>
                <button class="btn btn-danger" @onclick="DeleteOrder">@AppText.DeleteTitle</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Order> allOrders = new();
    private List<Order> filteredOrders = new();
    private List<Carrier> carriers = new();
    private List<OrderTracker.Models.PaymentMethod> paymentMethods = new();
    private bool loading = true;
    private string searchText = string.Empty;
    private string selectedStatus = string.Empty;
    private string sortField = "date-desc";
    private bool showModal;
    private Order? editingOrder;
    private Order? orderToDelete;
    private string formError = string.Empty;
    private bool saving;

    private int? openDropdownId;
    private int currentPage = 1;
    private int pageSize = 10;
    private bool pageSizeDropdownOpen;
    private DotNetObjectReference<Orders>? selfRef;
    private double dropdownTop;
    private double dropdownLeft;

    private int TotalPages => (int)Math.Ceiling(filteredOrders.Count / (double)pageSize);
    private List<Order> PagedOrders => filteredOrders.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();

    protected override async Task OnInitializedAsync()
    {
        carriers = await CarrierSvc.GetAllAsync();
        paymentMethods = await PaymentMethodSvc.GetAllAsync();
        await LoadOrders();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        selfRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("registerDropdownClose", selfRef);
        var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "orderPageSize");
        if (saved != null && int.TryParse(saved, out var savedSize) && new[] { 10, 15, 20 }.Contains(savedSize))
        {
            pageSize = savedSize;
            StateHasChanged();
        }
    }

    private async Task LoadOrders()
    {
        loading = true;
        allOrders = await OrderSvc.GetAllAsync();
        FilterOrders();
        loading = false;
    }

    private void FilterOrders()
    {
        var query = allOrders.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            var search = searchText.ToLower();
            query = query.Where(o => o.Store.ToLower().Contains(search) || (o.TrackingCode?.ToLower().Contains(search) ?? false));
        }

        if (!string.IsNullOrEmpty(selectedStatus) && Enum.TryParse<OrderStatus>(selectedStatus, out var status))
            query = query.Where(o => o.Status == status);

        query = sortField switch
        {
            "date-asc" => query.OrderBy(o => o.PurchaseDate),
            "price-desc" => query.OrderByDescending(o => o.TotalPrice),
            "price-asc" => query.OrderBy(o => o.TotalPrice),
            _ => query.OrderByDescending(o => o.PurchaseDate)
        };

        filteredOrders = query.ToList();
        currentPage = 1;
    }

    private void OpenCreateModal()
    {
        editingOrder = new Order { PurchaseDate = DateTime.Today };
        formError = string.Empty;
        showModal = true;
    }

    private void OpenEditModal(Order order)
    {
        editingOrder = new Order
        {
            Id = order.Id,
            Store = order.Store,
            PurchaseDate = order.PurchaseDate,
            CarrierId = order.CarrierId,
            TrackingCode = order.TrackingCode,
            TrackingUrl = order.TrackingUrl,
            Status = order.Status,
            EstimatedDelivery = order.EstimatedDelivery,
            ReceivedDate = order.ReceivedDate,
            PaymentMethodId = order.PaymentMethodId,
            Notes = order.Notes,
            TotalPrice = order.TotalPrice,
            Items = order.Items.Select(i => new OrderItem
            {
                Id = i.Id,
                ProductName = i.ProductName,
                Quantity = i.Quantity,
                UnitPrice = i.UnitPrice
            }).ToList()
        };

        formError = string.Empty;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingOrder = null;
    }

    private void AddItem() => editingOrder?.Items.Add(new OrderItem { Quantity = 1 });

    private void RemoveItem(OrderItem item)
    {
        editingOrder?.Items.Remove(item);
        RecalcTotal();
    }

    private void RecalcTotal()
    {
        if (editingOrder != null)
            editingOrder.TotalPrice = editingOrder.Items.Sum(i => i.Quantity * i.UnitPrice);
    }

    private async Task SaveOrder()
    {
        if (editingOrder == null)
            return;

        if (string.IsNullOrWhiteSpace(editingOrder.Store))
        {
            formError = AppText.OrderStoreRequiredWithPeriod;
            return;
        }

        saving = true;
        formError = string.Empty;
        RecalcTotal();

        if (editingOrder.Id == 0)
            await OrderSvc.CreateAsync(editingOrder);
        else
            await OrderSvc.UpdateAsync(editingOrder);

        saving = false;
        showModal = false;
        editingOrder = null;
        await LoadOrders();
    }

    private void GoToPage(int page)
    {
        currentPage = page;
        openDropdownId = null;
    }

    private void PrevPage()
    {
        if (currentPage > 1)
            currentPage--;
    }

    private void NextPage()
    {
        if (currentPage < TotalPages)
            currentPage++;
    }

    private void TogglePageSizeDropdown() => pageSizeDropdownOpen = !pageSizeDropdownOpen;

    private async Task SetPageSize(int size)
    {
        pageSize = size;
        currentPage = 1;
        pageSizeDropdownOpen = false;
        await JS.InvokeVoidAsync("localStorage.setItem", "orderPageSize", pageSize.ToString());
    }

    [JSInvokable]
    public void CloseDropdown()
    {
        openDropdownId = null;
        pageSizeDropdownOpen = false;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        await JS.InvokeVoidAsync("unregisterDropdownClose");
        selfRef?.Dispose();
    }

    private void ToggleDropdown(int orderId, MouseEventArgs e)
    {
        if (openDropdownId == orderId)
        {
            openDropdownId = null;
        }
        else
        {
            openDropdownId = orderId;
            dropdownTop = e.ClientY + 8;
            dropdownLeft = e.ClientX - 10;
        }
    }

    private async Task ChangeStatusFromDropdown(int orderId, OrderStatus status)
    {
        openDropdownId = null;
        await OrderSvc.UpdateStatusAsync(orderId, status);
        var order = allOrders.FirstOrDefault(o => o.Id == orderId);
        if (order != null)
            order.Status = status;
        FilterOrders();
    }

    private void ConfirmDelete(Order order) => orderToDelete = order;

    private void CancelDelete() => orderToDelete = null;

    private async Task DeleteOrder()
    {
        if (orderToDelete == null)
            return;

        await OrderSvc.SoftDeleteAsync(orderToDelete.Id);
        orderToDelete = null;
        await LoadOrders();
    }

    private static bool IsDelayed(Order order) =>
        order.EstimatedDelivery.HasValue &&
        order.EstimatedDelivery.Value.Date < DateTime.Today &&
        order.Status != OrderStatus.Recibido &&
        order.Status != OrderStatus.Cancelado;
}
