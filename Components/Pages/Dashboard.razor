@page "/"
@using OrderTracker.Services
@using OrderTracker.DTOs
@using OrderTracker.Models
@inject OrderService OrderSvc
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>@AppText.PageTitleDashboard</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">@AppText.DashboardTitle</h1>
    </div>
</div>

@if (metrics == null)
{
    <div class="loading-state">@AppText.LoadMetrics</div>
}
else
{
    <div class="metrics-grid">
        <div class="metric-card metric-pending">
            <div class="metric-icon">🕐</div>
            <div class="metric-info">
                <span class="metric-value">@metrics.TotalPending</span>
                <span class="metric-label">@AppText.MetricPending</span>
            </div>
        </div>
        <div class="metric-card metric-delivery">
            <div class="metric-icon">🚚</div>
            <div class="metric-info">
                <span class="metric-value">@metrics.InDelivery</span>
                <span class="metric-label">@AppText.MetricInDelivery</span>
            </div>
        </div>
        <div class="metric-card metric-delayed">
            <div class="metric-icon">⚠</div>
            <div class="metric-info">
                <span class="metric-value">@metrics.Delayed</span>
                <span class="metric-label">@AppText.MetricDelayed</span>
            </div>
        </div>
        <div class="metric-card metric-spent">
            <div class="metric-icon">@AppText.EuroSymbol</div>
            <div class="metric-info">
                <span class="metric-value">@AppText.FormatCurrency(metrics.TotalSpent)</span>
                <span class="metric-label">@AppText.MetricTotalSpent</span>
            </div>
        </div>
    </div>

    <div class="dashboard-sections">
        <div class="section-card">
            <h2 class="section-title">@AppText.RecentOrdersTitle</h2>
            @if (recentOrders.Any())
            {
                <div class="orders-preview">
                    @foreach (var order in recentOrders)
                    {
                        <div class="order-preview-row">
                            <div class="order-preview-store">@order.Store</div>
                            <div class="order-preview-date">@order.PurchaseDate.ToString("dd/MM/yyyy")</div>
                            <span class="status-badge status-@order.Status.ToString().ToLower()">@AppText.GetOrderStatusLabel(order.Status)</span>
                            <div class="order-preview-price">@AppText.FormatCurrency(order.TotalPrice)</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state-small">@AppText.NoOrdersYetMessage <a href="/orders">@AppText.CreateFirstOrderLinkText</a></div>
            }
        </div>

        <div class="section-card">
            <h2 class="section-title">@AppText.ByStatusTitle</h2>
            <div class="status-breakdown">
                @foreach (var statusGroup in statusBreakdown)
                {
                    <div class="status-breakdown-row">
                        <span class="status-badge status-@statusGroup.Key.ToString().ToLower()">@AppText.GetOrderStatusLabel(statusGroup.Key)</span>
                        <div class="status-bar-wrap">
                            <div class="status-bar" style="width: @(metrics.TotalOrders > 0 ? (statusGroup.Value * 100 / metrics.TotalOrders) : 0)%"></div>
                        </div>
                        <span class="status-count">@statusGroup.Value</span>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    private DashboardMetrics? metrics;
    private List<Order> recentOrders = new();
    private Dictionary<OrderStatus, int> statusBreakdown = new();

    protected override async Task OnInitializedAsync()
    {
        metrics = await OrderSvc.GetMetricsAsync();
        var all = await OrderSvc.GetAllAsync();
        recentOrders = all.Take(5).ToList();
        statusBreakdown = all
            .GroupBy(o => o.Status)
            .ToDictionary(g => g.Key, g => g.Count());
    }
}
