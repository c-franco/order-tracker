@page "/settings"
@using OrderTracker.Services
@using OrderTracker.Models
@inject CarrierService CarrierSvc
@inject PaymentMethodService PaymentMethodSvc
@inject OrderService OrderSvc
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>📦 Order Tracker — Ajustes</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">Ajustes</h1>
    </div>
</div>

<div class="settings-container">
    <div class="settings-section">
        <div class="settings-section-header">
            <div>
                <h2 class="settings-section-title">Transportistas</h2>
                <p class="settings-section-desc">Gestiona la lista de empresas de reparto y sus URLs de seguimiento.</p>
            </div>
            <button class="btn btn-secondary" @onclick="AddCarrier">+ Añadir transportista</button>
        </div>

        @if (loading)
        {
            <div class="loading-state">Cargando transportistas...</div>
        }
        else
        {
            <div class="carriers-table-wrap">
                <table class="carriers-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>URL de seguimiento <span class="th-hint">usa {0} como placeholder del código</span></th>
                            <th>Orden</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var carrier in carriers)
                        {
                            <tr>
                                <td>
                                    <input class="form-input" @bind="carrier.Name" placeholder="Nombre del transportista" />
                                </td>
                                <td>
                                    <input class="form-input" @bind="carrier.TrackingUrlTemplate" placeholder="https://ejemplo.com/tracking/{0}" />
                                </td>
                                <td>
                                    <input class="form-input form-input-xs" type="number" min="0" @bind="carrier.SortOrder" />
                                </td>
                                <td>
                                    <button class="btn-icon btn-delete" @onclick="() => RemoveCarrier(carrier)" title="Eliminar">✕</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!string.IsNullOrEmpty(saveMessage))
            {
                <div class="save-message @(saveError ? "save-error" : "save-success")">@saveMessage</div>
            }

            <div class="settings-actions">
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                    @(saving ? "Guardando..." : "Guardar cambios")
                </button>
            </div>
        }
    </div>
    <div class="settings-section">
        <div class="settings-section-header">
            <div>
                <h2 class="settings-section-title">Métodos de pago</h2>
                <p class="settings-section-desc">Gestiona las opciones de método de pago disponibles en los pedidos.</p>
            </div>
            <button class="btn btn-secondary" @onclick="AddPaymentMethod">+ Añadir método</button>
        </div>

        @if (loadingPm)
        {
            <div class="loading-state">Cargando métodos de pago...</div>
        }
        else
        {
            <div class="carriers-table-wrap">
                <table class="carriers-table">
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Orden</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pm in paymentMethods)
                        {
                            <tr>
                                <td><input class="form-input" @bind="pm.Name" placeholder="Nombre del método" /></td>
                                <td><input class="form-input form-input-xs" type="number" min="0" @bind="pm.SortOrder" /></td>
                                <td><button class="btn-icon btn-delete" @onclick="() => paymentMethods.Remove(pm)" title="Eliminar">✕</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!string.IsNullOrEmpty(savePmMessage))
            {
                <div class="save-message @(savePmError ? "save-error" : "save-success")">@savePmMessage</div>
            }

            <div class="settings-actions">
                <button class="btn btn-primary" @onclick="SavePaymentMethods" disabled="@savingPm">
                    @(savingPm ? "Guardando..." : "Guardar cambios")
                </button>
            </div>
        }
    </div>
    <div class="settings-section">
        <div class="settings-section-header">
            <div>
                <h2 class="settings-section-title">Datos</h2>
                <p class="settings-section-desc">Exporta todos tus pedidos a CSV o importa pedidos desde un archivo CSV exportado previamente.</p>
            </div>
        </div>
        <div class="data-actions">
            <button class="btn btn-secondary" @onclick="ExportCsv" disabled="@exporting">
                @(exporting ? "Exportando..." : "↓ Exportar CSV")
            </button>
            <button class="btn btn-secondary" @onclick="() => showImportModal = true">↑ Importar CSV</button>
        </div>
    </div>
</div>

@if (showImportModal)
{
    <div class="modal-overlay" @onclick="() => { showImportModal = false; importResult = null; }">
        <div class="modal-panel modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">Importar CSV</h2>
                <button class="modal-close" @onclick="() => { showImportModal = false; importResult = null; }">✕</button>
            </div>
            <div class="modal-body">
                @if (importResult == null)
                {
                    <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 16px;">
                        Selecciona un archivo CSV exportado previamente desde esta aplicación.
                        Los pedidos se añadirán sin reemplazar los existentes.
                    </p>
                    <InputFile class="form-input" accept=".csv" OnChange="HandleImportFile" />
                    @if (!string.IsNullOrEmpty(importError))
                    {
                        <div class="form-error" style="margin-top: 12px;">@importError</div>
                    }
                    @if (importing)
                    {
                        <div class="loading-state" style="padding: 16px 0;">Importando...</div>
                    }
                }
                else
                {
                    <div class="import-result">
                        <div class="import-stat @(importResult.Value.imported > 0 ? "import-ok" : "")">
                            ✓ @importResult.Value.imported pedido@(importResult.Value.imported != 1 ? "s" : "") importado@(importResult.Value.imported != 1 ? "s" : "")
                        </div>
                        @if (importResult.Value.skipped > 0)
                        {
                            <div class="import-stat import-warn">
                                ⚠ @importResult.Value.skipped fila@(importResult.Value.skipped != 1 ? "s" : "") omitida@(importResult.Value.skipped != 1 ? "s" : "")
                            </div>
                        }
                        @if (importResult.Value.errors.Any())
                        {
                            <div class="import-errors">
                                @foreach (var err in importResult.Value.errors)
                                {
                                    <div class="import-error-line">@err</div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="() => { showImportModal = false; importResult = null; }">Cerrar</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Carrier> carriers = new();
    private List<OrderTracker.Models.PaymentMethod> paymentMethods = new();
    private bool loadingPm = true;
    private bool savingPm = false;
    private string savePmMessage = "";
    private bool savePmError = false;
    private bool loading = true;
    private bool exporting = false;
    private bool showImportModal = false;
    private bool importing = false;
    private string importError = "";
    private (int imported, int skipped, List<string> errors)? importResult = null;
    private bool saving = false;
    private string saveMessage = "";
    private bool saveError = false;

    protected override async Task OnInitializedAsync()
    {
        carriers = await CarrierSvc.GetAllAsync();
        loading = false;
        paymentMethods = await PaymentMethodSvc.GetAllAsync();
        loadingPm = false;
    }

    private void AddCarrier()
    {
        carriers.Add(new Carrier { SortOrder = carriers.Count > 0 ? carriers.Max(c => c.SortOrder) + 1 : 1 });
    }

    private void RemoveCarrier(Carrier carrier)
    {
        carriers.Remove(carrier);
    }

    private void AddPaymentMethod()
    {
        paymentMethods.Add(new OrderTracker.Models.PaymentMethod
        {
            SortOrder = paymentMethods.Count > 0 ? paymentMethods.Max(p => p.SortOrder) + 1 : 1
        });
    }

    private async Task SavePaymentMethods()
    {
        savingPm = true;
        savePmMessage = "";
        try
        {
            await PaymentMethodSvc.SaveAllAsync(paymentMethods);
            savePmMessage = "✓ Cambios guardados correctamente.";
            savePmError = false;
            paymentMethods = await PaymentMethodSvc.GetAllAsync();
        }
        catch (Exception ex)
        {
            savePmMessage = $"Error al guardar: {ex.Message}";
            savePmError = true;
        }
        savingPm = false;
    }

    private async Task Save()
    {
        saving = true;
        saveMessage = "";

        try
        {
            await CarrierSvc.SaveAllAsync(carriers);
            saveMessage = "✓ Cambios guardados correctamente.";
            saveError = false;
            carriers = await CarrierSvc.GetAllAsync();
        }
        catch (Exception ex)
        {
            saveMessage = $"Error al guardar: {ex.Message}";
            saveError = true;
        }

        saving = false;
    }

    private async Task ExportCsv()
    {
        exporting = true;
        var csv = await OrderSvc.ExportToCsvAsync();
        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);
        var filename = $"pedidos_{DateTime.Now:yyyyMMdd_HHmmss}.csv";
        await JS.InvokeVoidAsync("downloadFile", filename, "text/csv;charset=utf-8;", base64);
        exporting = false;
    }

    private async Task HandleImportFile(InputFileChangeEventArgs e)
    {
        importError = "";
        importing = true;
        importResult = null;

        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream, System.Text.Encoding.UTF8);
            var csv = await reader.ReadToEndAsync();
            var carrierList = await CarrierSvc.GetAllAsync();
            var pmList = await PaymentMethodSvc.GetAllAsync();
            importResult = await OrderSvc.ImportFromCsvAsync(csv, carrierList, pmList);
        }
        catch (Exception ex)
        {
            importError = "Error al leer el archivo: " + ex.Message;
        }

        importing = false;
    }
}
