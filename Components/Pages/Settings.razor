@page "/settings"
@using OrderTracker.Services
@using OrderTracker.Models
@inject CarrierService CarrierSvc
@inject PaymentMethodService PaymentMethodSvc
@inject OrderService OrderSvc
@inject IJSRuntime JS
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>@AppText.PageTitleSettings</PageTitle>

<div class="page-header">
    <div>
        <h1 class="page-title">@AppText.SettingsTitle</h1>
    </div>
</div>

<div class="settings-container">
    <div class="settings-section">
        <div class="settings-section-header">
            <div>
                <h2 class="settings-section-title">@AppText.DataSectionTitle</h2>
                <p class="settings-section-desc">@AppText.DataSectionDescription</p>
            </div>
        </div>
        <div class="data-actions">
            <button class="btn btn-secondary" @onclick="ExportCsv" disabled="@exporting">
                @(exporting ? AppText.Exporting : AppText.ExportCsvButton)
            </button>
            <button class="btn btn-secondary" @onclick="() => showImportModal = true">@AppText.ImportCsvButton</button>
        </div>
    </div>

    <div class="settings-section">
        <div class="settings-section-header">
            <div>
                <h2 class="settings-section-title">@AppText.PaymentMethodsTitle</h2>
            </div>
        </div>
        @if (loadingPm)
        {
            <div class="loading-state">@AppText.Loading</div>
        }
        else
        {
            <div class="chips-wrap">
                @foreach (var pm in paymentMethods.ToList())
                {
                    <div class="chip">
                        <input class="chip-input" @bind="pm.Name" placeholder="@AppText.PaymentMethodPlaceholder" />
                        <button class="chip-remove" @onclick="() => paymentMethods.Remove(pm)" title="@AppText.DeleteTitle">@AppText.CloseIcon</button>
                    </div>
                }
                <button class="chip chip-add" @onclick="AddPaymentMethod">@AppText.AddButton</button>
            </div>

            <div class="accordion-footer">
                @if (!string.IsNullOrEmpty(savePmMessage))
                {
                    <span class="inline-save-msg @(savePmError ? "save-error" : "save-success")">@savePmMessage</span>
                }
                <button class="btn btn-primary btn-sm" @onclick="SavePaymentMethods" disabled="@savingPm">
                    @(savingPm ? AppText.Saving : AppText.SaveButton)
                </button>
            </div>
        }
    </div>

    <div class="settings-section">
        <div class="accordion-header" @onclick="() => carriersOpen = !carriersOpen">
            <div class="accordion-title-wrap">
                <h2 class="settings-section-title">@AppText.CarriersTitle</h2>
                <span class="accordion-count">@carriers.Count</span>
            </div>
            <span class="accordion-arrow @(carriersOpen ? "open" : string.Empty)">@AppText.NextPageArrow</span>
        </div>

        @if (carriersOpen)
        {
            <div class="accordion-body">
                @if (loading)
                {
                    <div class="loading-state">@AppText.Loading</div>
                }
                else
                {
                    <div class="carriers-table-wrap">
                        <table class="carriers-table">
                            <thead>
                                <tr>
                                    <th>@AppText.CarrierNameColumn</th>
                                    <th>@AppText.CarrierTrackingUrlColumn <span class="th-hint">@AppText.CarrierTrackingUrlHint</span></th>
                                    <th>@AppText.SortOrderColumn</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var carrier in carriers)
                                {
                                    <tr>
                                        <td><input class="form-input" @bind="carrier.Name" placeholder="@AppText.CarrierNamePlaceholder" /></td>
                                        <td><input class="form-input" @bind="carrier.TrackingUrlTemplate" placeholder="@AppText.CarrierTrackingUrlPlaceholder" /></td>
                                        <td><input class="form-input form-input-xs" type="number" min="0" @bind="carrier.SortOrder" /></td>
                                        <td><button class="btn-icon btn-delete" @onclick="() => RemoveCarrier(carrier)" title="@AppText.DeleteTitle">@AppText.CloseIcon</button></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="accordion-footer">
                        <button class="btn btn-secondary btn-sm" @onclick="AddCarrier">@AppText.AddButton</button>
                        @if (!string.IsNullOrEmpty(saveMessage))
                        {
                            <span class="inline-save-msg @(saveError ? "save-error" : "save-success")">@saveMessage</span>
                        }
                        <button class="btn btn-primary btn-sm" @onclick="Save" disabled="@saving">
                            @(saving ? AppText.Saving : AppText.SaveButton)
                        </button>
                    </div>
                }
            </div>
        }
    </div>
</div>

@if (showImportModal)
{
    <div class="modal-overlay" @onclick="CloseImportModal">
        <div class="modal-panel modal-sm" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2 class="modal-title">@AppText.ImportCsvTitle</h2>
                <button class="modal-close" @onclick="CloseImportModal">@AppText.CloseIcon</button>
            </div>
            <div class="modal-body">
                @if (importResult == null)
                {
                    <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 16px;">
                        @AppText.ImportCsvDescription
                    </p>
                    <InputFile class="form-input" accept=".csv" OnChange="HandleImportFile" />
                    @if (!string.IsNullOrEmpty(importError))
                    {
                        <div class="form-error" style="margin-top: 12px;">@importError</div>
                    }
                    @if (importing)
                    {
                        <div class="loading-state" style="padding: 16px 0;">@AppText.Importing</div>
                    }
                }
                else
                {
                    <div class="import-result">
                        <div class="import-stat @(importResult.Value.imported > 0 ? "import-ok" : string.Empty)">
                            @AppText.FormatImportedOrders(importResult.Value.imported)
                        </div>
                        @if (importResult.Value.skipped > 0)
                        {
                            <div class="import-stat import-warn">
                                @AppText.FormatSkippedRows(importResult.Value.skipped)
                            </div>
                        }
                        @if (importResult.Value.errors.Any())
                        {
                            <div class="import-errors">
                                @foreach (var err in importResult.Value.errors)
                                {
                                    <div class="import-error-line">@err</div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button class="btn btn-ghost" @onclick="CloseImportModal">@AppText.CloseButton</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Carrier> carriers = new();
    private List<OrderTracker.Models.PaymentMethod> paymentMethods = new();
    private bool carriersOpen;
    private bool loading = true;
    private bool saving;
    private string saveMessage = string.Empty;
    private bool saveError;
    private bool loadingPm = true;
    private bool savingPm;
    private string savePmMessage = string.Empty;
    private bool savePmError;
    private bool exporting;
    private bool showImportModal;
    private bool importing;
    private string importError = string.Empty;
    private (int imported, int skipped, List<string> errors)? importResult;

    protected override async Task OnInitializedAsync()
    {
        carriers = await CarrierSvc.GetAllAsync();
        loading = false;
        paymentMethods = await PaymentMethodSvc.GetAllAsync();
        loadingPm = false;
    }

    private void AddCarrier() =>
        carriers.Add(new Carrier { SortOrder = carriers.Count > 0 ? carriers.Max(c => c.SortOrder) + 1 : 1 });

    private void RemoveCarrier(Carrier carrier) => carriers.Remove(carrier);

    private void AddPaymentMethod() =>
        paymentMethods.Add(new OrderTracker.Models.PaymentMethod
        {
            SortOrder = paymentMethods.Count > 0 ? paymentMethods.Max(p => p.SortOrder) + 1 : 1
        });

    private async Task Save()
    {
        saving = true;
        saveMessage = string.Empty;
        try
        {
            await CarrierSvc.SaveAllAsync(carriers);
            saveMessage = AppText.SaveSuccessMessage;
            saveError = false;
            carriers = await CarrierSvc.GetAllAsync();
        }
        catch (Exception ex)
        {
            saveMessage = AppText.FormatGenericError(ex.Message);
            saveError = true;
        }

        saving = false;
    }

    private async Task SavePaymentMethods()
    {
        savingPm = true;
        savePmMessage = string.Empty;
        try
        {
            await PaymentMethodSvc.SaveAllAsync(paymentMethods);
            savePmMessage = AppText.SaveSuccessMessage;
            savePmError = false;
            paymentMethods = await PaymentMethodSvc.GetAllAsync();
        }
        catch (Exception ex)
        {
            savePmMessage = AppText.FormatGenericError(ex.Message);
            savePmError = true;
        }

        savingPm = false;
    }

    private async Task ExportCsv()
    {
        exporting = true;
        var csv = await OrderSvc.ExportToCsvAsync();
        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);
        var filename = AppText.FormatExportFileName(DateTime.Now);
        await JS.InvokeVoidAsync("downloadFile", filename, "text/csv;charset=utf-8;", base64);
        exporting = false;
    }

    private async Task HandleImportFile(InputFileChangeEventArgs e)
    {
        importError = string.Empty;
        importing = true;
        importResult = null;

        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream, System.Text.Encoding.UTF8);
            var csv = await reader.ReadToEndAsync();
            var carrierList = await CarrierSvc.GetAllAsync();
            var pmList = await PaymentMethodSvc.GetAllAsync();
            importResult = await OrderSvc.ImportFromCsvAsync(csv, carrierList, pmList);
        }
        catch (Exception ex)
        {
            importError = AppText.FormatReadFileError(ex.Message);
        }

        importing = false;
    }

    private void CloseImportModal()
    {
        showImportModal = false;
        importResult = null;
    }
}
