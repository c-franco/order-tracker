<!DOCTYPE html>
<html lang="es" data-theme="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>📦 Order Tracker</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/app.css" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.server.js"></script>
    <script>
        let _dropdownRef = null;
        function _onDocClick(e) {
            if (e.target.closest('.custom-dropdown')) return;
            if (_dropdownRef) _dropdownRef.invokeMethodAsync('CloseDropdown');
        }
        function registerDropdownClose(ref) {
            _dropdownRef = ref;
            document.addEventListener('click', _onDocClick);
        }
        function unregisterDropdownClose() {
            document.removeEventListener('click', _onDocClick);
            _dropdownRef = null;
        }
    </script>
</body>

</html>
