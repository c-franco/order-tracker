@inherits LayoutComponentBase

<div class="app-shell">
    <HamburgerMenu />

    <main class="main-content">
        <div class="mobile-topbar">
            <div id="hamburger-slot"></div>
            <span class="mobile-brand">📦 OrderTracker</span>
            <button class="theme-toggle-mobile" onclick="toggleTheme()" title="Cambiar tema">
                <span id="theme-icon-mobile">☀</span>
            </button>
        </div>

        <div class="content-wrapper">
            @Body
        </div>
    </main>
</div>

<script>
    function toggleTheme() {
        const html = document.documentElement;
        const current = html.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-theme', next);
        const icon = next === 'dark' ? '☀' : '◑';
        ['theme-icon','theme-icon-mobile'].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.textContent = icon;
        });
        localStorage.setItem('theme', next);
    }
    const saved = localStorage.getItem('theme') || 'dark';
    document.documentElement.setAttribute('data-theme', saved);
    const icon = saved === 'dark' ? '☀' : '◑';
    ['theme-icon','theme-icon-mobile'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = icon;
    });

    // Move hamburger button into topbar slot after render
    function moveHamburger() {
        const wrap = document.querySelector('.hamburger-wrap');
        const slot = document.getElementById('hamburger-slot');
        if (wrap && slot && !slot.contains(wrap)) {
            slot.appendChild(wrap);
        }
    }
    document.addEventListener('DOMContentLoaded', moveHamburger);
    // Also try after Blazor updates
    const obs = new MutationObserver(moveHamburger);
    obs.observe(document.body, { childList: true, subtree: true });
</script>
